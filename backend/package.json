{
  "name": "jimo-east-backend",
  "version": "1.0.0",
  "description": "Production REST API for Jimo East Chief Digital Services Portal — Kenya NGAO",
  "main": "server.js",
  "scripts": {
    "start":        "node server.js",
    "dev":          "nodemon --watch . --ext js,json --ignore uploads/ --ignore logs/ server.js",
    "lint":         "eslint . --ext .js --ignore-pattern node_modules/ --ignore-pattern uploads/ --ignore-pattern logs/",
    "lint:fix":     "eslint . --ext .js --fix --ignore-pattern node_modules/",
    "test":         "jest --coverage --forceExit --detectOpenHandles",
    "test:watch":   "jest --watch",
    "seed":         "node utils/seed.js",
    "seed:destroy": "node utils/seed.js --destroy"
  },
  "dependencies": {
    "africastalking":          "^1.3.3",
    "bcryptjs":                "^2.4.3",
    "compression":             "^1.7.4",
    "cors":                    "^2.8.5",
    "dotenv":                  "^16.4.5",
    "express":                 "^4.19.2",
    "express-mongo-sanitize":  "^2.2.0",
    "express-rate-limit":      "^7.3.1",
    "express-validator":       "^7.1.0",
    "helmet":                  "^7.1.0",
    "jsonwebtoken":            "^9.0.2",
    "mongoose":                "^8.4.1",
    "morgan":                  "^1.10.0",
    "multer":                  "^1.4.5-lts.1",
    "pdfkit":                  "^0.15.0",
    "swagger-jsdoc":           "^6.2.8",
    "swagger-ui-express":      "^5.0.1",
    "winston":                 "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint":      "^8.57.0",
    "jest":        "^29.7.0",
    "nodemon":     "^3.1.3",
    "supertest":   "^7.0.0"
  },
  "jest": {
    "testEnvironment":  "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "middlewares/**/*.js",
      "utils/**/*.js"
    ],
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js", "**/*.spec.js"],
    "testPathIgnorePatterns": ["/node_modules/", "/uploads/", "/logs/"]
  },
  "nodemonConfig": {
    "watch":  ["controllers", "routes", "models", "middlewares", "services", "utils", "config", "server.js"],
    "ext":    "js,json",
    "ignore": ["uploads/", "logs/", "*.test.js", "*.spec.js"],
    "delay":  "500"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  },
  "author":  "Jimo East NGAO GovTech",
  "license": "MIT"
}
